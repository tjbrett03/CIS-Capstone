# Secret key used by Flask to sign session cookies. Change this to a random value in production.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-me

# Password required to access the app.
APP_PASSWORD=change-me

# Set to true to enable Flask debug mode and auto-reload on code changes.
FLASK_DEBUG=false

# Set to true to show a debug panel in the interview UI with context window usage and message history.
DEBUG_CONTEXT=false

# Base URL for the Ollama API. Change this if Ollama is running on a different host or port.
OLLAMA_URL=http://localhost:11434

# The Ollama model to use. Must be pulled locally before running (e.g. ollama pull llama3.1:8b).
# Recommended: llama3.1:8b — good balance of quality and speed on consumer hardware.
LLM_MODEL=llama3.1:8b

# Number of tokens to allocate for the context window.
# 16384 is recommended for llama3.1:8b on a 12GB GPU. Lower this for less VRAM.
# A typical interview uses under 2,000 tokens, so 4096 is sufficient on limited hardware.
LLM_NUM_CTX=16384

# Controls response randomness. Lower values are more focused and instruction-following.
# Recommended: 0.2 for structured interview use.
LLM_TEMPERATURE=0.2
